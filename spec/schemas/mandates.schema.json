{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kiosk.tech/spec/schemas/mandates.schema.json",
  "title": "Kiosk AP2 payment mandates",
  "description": "The decoded JWS payloads of the three AP2 mandates and the POST /kiosk/pay request body. On the wire each mandate is an RS256 compact JWS string; these schemas describe the decoded claim sets.",
  "$defs": {
    "baseClaims": {
      "type": "object",
      "description": "Claims every mandate MUST carry.",
      "required": ["id", "user_id", "agent_id", "iss", "iat", "exp"],
      "properties": {
        "id": { "type": "string", "description": "Unique mandate id." },
        "user_id": { "type": "string", "description": "MUST match the authenticated identity (string-compared)." },
        "agent_id": { "type": "string", "description": "MUST match the authenticated identity (string-compared)." },
        "iss": { "type": "string", "description": "MUST equal the provider issuer from /.well-known/kiosk.json, verbatim." },
        "iat": { "type": "integer" },
        "exp": { "type": "integer", "description": "REQUIRED; a missing or passed exp is rejected." }
      }
    },
    "intent": {
      "allOf": [{ "$ref": "#/$defs/baseClaims" }],
      "type": "object",
      "required": ["cap_amount_cents", "currency"],
      "properties": {
        "cap_amount_cents": { "type": "integer", "description": "Spending cap; REQUIRED (a nil cap is rejected)." },
        "currency": { "type": "string", "description": "ISO 4217 code; REQUIRED." },
        "scope": { "type": "string", "description": "Optional provider-defined scope." }
      }
    },
    "cart": {
      "allOf": [{ "$ref": "#/$defs/baseClaims" }],
      "type": "object",
      "required": ["intent_mandate_id", "total_amount_cents", "currency"],
      "properties": {
        "intent_mandate_id": { "type": "string", "description": "MUST equal the intent mandate id; cart total MUST NOT exceed the intent cap." },
        "total_amount_cents": { "type": "integer", "description": "REQUIRED." },
        "currency": { "type": "string", "description": "MUST equal the intent currency." },
        "line_items": { "type": "array", "description": "Optional provider-defined line items." }
      }
    },
    "payment": {
      "allOf": [{ "$ref": "#/$defs/baseClaims" }],
      "type": "object",
      "required": ["cart_mandate_id", "amount_cents", "currency"],
      "properties": {
        "cart_mandate_id": { "type": "string", "description": "MUST equal the cart mandate id." },
        "amount_cents": { "type": "integer", "description": "MUST equal the cart total, same currency." },
        "currency": { "type": "string" },
        "payment_method": { "type": "string", "description": "Optional PSP method identifier (e.g. \"on_file\")." }
      }
    },
    "payRequest": {
      "type": "object",
      "description": "The POST /kiosk/pay request body: the three mandates as compact JWS strings.",
      "required": ["intent_mandate_jws", "cart_mandate_jws", "payment_mandate_jws"],
      "properties": {
        "intent_mandate_jws": { "type": "string" },
        "cart_mandate_jws": { "type": "string" },
        "payment_mandate_jws": { "type": "string" }
      }
    },
    "settlement": {
      "type": "object",
      "description": "The value of the kind:\"value\" pay response.",
      "required": ["settlement_id", "psp_reference", "settled_amount_cents", "currency"],
      "properties": {
        "settlement_id": { "type": "string" },
        "psp_reference": { "type": "string" },
        "settled_amount_cents": { "type": "integer" },
        "currency": { "type": "string" }
      }
    }
  }
}
